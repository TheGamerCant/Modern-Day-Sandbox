	scale = 1.4
}

entity = {
	name = "westerngfx_house_1_2"
	pdxmesh = "westerngfx_house_1_2"
	scale = 1.8
}

entity = {
	name = "westerngfx_house_1_3"
	pdxmesh = "westerngfx_house_1_3"
	scale = 1.8
	locator = { name = "damage_locator_01"	position = { 0.4 0.0 0.4 } }
	locator = { name = "damage_locator_02"	position = { -0.1 0.0 -0.3 } }
	locator = { name = "damage_locator_03"	position = { 0.3 0.0 0.5 } }
	locator = { name = "damage_locator_04"	position = { -0.15 0.0 -0.2 } }
	
	default_state = "idle"
	state = { name = "idle"
	}
	state = { name = "damaged" 
		event = { time = 0.1 node="damage_locator_03" particle = "city_smoke_particle" }
	}
	state = { name = "burning" 
		event = { time = 0.1 node="damage_locator_01" particle = "city_fire_l_particle" }
		event = { time = 0.2 node="damage_locator_02" particle = "city_fire_2_particle" }
	}
}

